# Qmail Environment Variables
# ============================
# Phone authentication only - no Firebase or OAuth required

# Session & Security
ENV=development
ENFORCE_HTTPS=0
SESSION_TIMEOUT_SECONDS=3600
SENSITIVE_OPS_REAUTH_WINDOW=300

# CORS (development only)
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:8000

# Database
# Production: PostgreSQL (recommended)
DATABASE_URL=postgresql://qmail:qmail_dev_password@localhost:5432/qmail
# Development: SQLite (fallback)
# DATABASE_URL=sqlite:///qmail.db

# Redis (optional, for production token revocation)
REDIS_URL=

# Logging
LOG_LEVEL=INFO

# API Server Configuration
# ========================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# API Backend URL (for Flutter)
# ==============================
API_BASE_URL=https://qmail-api.onrender.com

# QRNG Configuration
# ==================
QRNG_BASE_URL=https://qrng.anu.edu.au/API/jsonI.php
QRNG_API_KEY=

# Database Encryption (Docker/Cloud only)
# =========================================
# Required when running in Docker/Cloud where OS keyring is unavailable
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DB_ENCRYPTION_MASTER_KEY=

# JWT Configuration
# =================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Phone Authentication (Twilio)
# ==============================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
